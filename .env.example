# Copy this file to .env and fill in the values.
# .env is gitignored.

# Required for LLM agents
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: LangSmith tracing (recommended)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=eom-poc-v2

# Optional: override default model
# EOM_MODEL=gpt-4.1-mini
